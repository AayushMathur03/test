@model ProductManagement.DTOs.ProductRequestDTOs
@{
    Layout = null;
    var productId = ViewBag.ProductId;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Delete Product</title>
    <style>
        body { font-family: Arial, sans-serif; margin: 0; padding: 24px; background: #f5f7fb; color: #1f2937; }
        .container { max-width: 700px; margin: 0 auto; background: #fff; border-radius: 12px; padding: 24px; box-shadow: 0 10px 30px rgba(0,0,0,.08); }
        .warning { padding: 12px 14px; background: #fef2f2; color: #991b1b; border: 1px solid #fecaca; border-radius: 8px; }
        .actions { margin-top: 20px; display: flex; gap: 12px; }
        button, a.btn { border: 0; border-radius: 8px; padding: 10px 16px; text-decoration: none; display: inline-block; }
        button { background: #dc2626; color: #fff; cursor: pointer; }
        a.btn { background: #e5e7eb; color: #111827; }
    </style>
</head>
<body>
    <div class="container">
        <h1>Delete Product</h1>
        <div class="warning">Are you sure you want to delete this product?</div>
        <p><strong>Id:</strong> @productId</p>
        <p><strong>Name:</strong> @Model?.Name</p>
        <p><strong>Price:</strong> @Model?.Price</p>
        <p><strong>Description:</strong> @Model?.Description</p>
        <form method="post" action="/Products/Delete/@productId">
            @Html.AntiForgeryToken()
            <div class="actions">
                <button type="submit">Delete</button>
                <a class="btn" href="/Products">Cancel</a>
            </div>
        </form>
    </div>
</body>
</html>